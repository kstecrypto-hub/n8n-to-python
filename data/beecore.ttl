@base <https://yourdomain.tld/ontologies/beecore#> .
@prefix beecore: <https://yourdomain.tld/ontologies/beecore#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

beecore: a owl:Ontology ;
  rdfs:label "BeeCore" ;
  owl:versionInfo "0.3.1" ;
  dcterms:description "Corpus-shaped ontology for beekeeping books covering colony biology, hive structure, equipment, products, forage, health, and management actions." .

##########
# Classes
##########

beecore:Apiary a owl:Class ;
  rdfs:label "Apiary" ;
  skos:altLabel "bee yard" .

beecore:ApiarySite a owl:Class ;
  rdfs:label "Apiary site" ;
  skos:altLabel "bee yard site" ;
  skos:altLabel "stand" .

