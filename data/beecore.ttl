##########
# Properties
##########

beecore:hasColony a owl:ObjectProperty ;
  rdfs:label "has colony" ;
  rdfs:domain beecore:Apiary ;
  rdfs:range beecore:Colony .

beecore:locatedAt a owl:ObjectProperty ;
  rdfs:label "located at" ;
  rdfs:domain beecore:Apiary ;
  rdfs:range beecore:ApiarySite .

beecore:hasQueen a owl:ObjectProperty ;
  rdfs:label "has queen" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:Queen .

beecore:hasMember a owl:ObjectProperty ;
  rdfs:label "has member" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:Bee .

beecore:hasBrood a owl:ObjectProperty ;
  rdfs:label "has brood" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:Brood .

beecore:usesHive a owl:ObjectProperty ;
  rdfs:label "uses hive" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:Hive .

beecore:hasComponent a owl:ObjectProperty ;
  rdfs:label "has component" ;
  rdfs:domain beecore:Hive ;
  rdfs:range beecore:HiveComponent .

beecore:containsCellType a owl:ObjectProperty ;
  rdfs:label "contains cell type" ;
  rdfs:domain beecore:Comb ;
  rdfs:range beecore:CombCell .

beecore:containsProduct a owl:ObjectProperty ;
  rdfs:label "contains product" ;
  rdfs:domain beecore:Comb ;
  rdfs:range beecore:HiveProduct .

beecore:storesResource a owl:ObjectProperty ;
  rdfs:label "stores resource" ;
  rdfs:domain beecore:Comb ;
  rdfs:range beecore:ForageResource .

beecore:produces a owl:ObjectProperty ;
  rdfs:label "produces" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:HiveProduct .

beecore:occupiesBroodNest a owl:ObjectProperty ;
  rdfs:label "occupies brood nest" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:BroodNest .

beecore:collects a owl:ObjectProperty ;
  rdfs:label "collects" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:ForageResource .

beecore:foragesOn a owl:ObjectProperty ;
  rdfs:label "forages on" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:FloralSource .

beecore:affectedBy a owl:ObjectProperty ;
  rdfs:label "affected by" ;
  rdfs:domain beecore:Colony ;
  rdfs:range beecore:HealthCondition .

beecore:hasSymptom a owl:ObjectProperty ;
  rdfs:label "has symptom" ;
  rdfs:domain beecore:HealthCondition ;
  rdfs:range beecore:Symptom .

beecore:treatedBy a owl:ObjectProperty ;
  rdfs:label "treated by" ;
  rdfs:domain beecore:HealthCondition ;
  rdfs:range beecore:Treatment .

beecore:requiresEquipment a owl:ObjectProperty ;
  rdfs:label "requires equipment" ;
  rdfs:domain beecore:ManagementAction ;
  rdfs:range beecore:Equipment .

beecore:usesComponent a owl:ObjectProperty ;
  rdfs:label "uses component" ;
  rdfs:domain beecore:ManagementAction ;
  rdfs:range beecore:HiveComponent .

beecore:feedsWith a owl:ObjectProperty ;
  rdfs:label "feeds with" ;
  rdfs:domain beecore:Feeding ;
  rdfs:range beecore:SupplementalFeed .

beecore:performedDuring a owl:ObjectProperty ;
  rdfs:label "performed during" ;
  rdfs:domain beecore:ManagementAction ;
