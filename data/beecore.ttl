  rdfs:range beecore:BeeSpace .

beecore:targets a owl:ObjectProperty ;
  rdfs:label "targets" ;
  rdfs:domain beecore:ManagementAction ;
  rdfs:range beecore:Colony .

beecore:prevents a owl:ObjectProperty ;
  rdfs:label "prevents" ;
  rdfs:domain beecore:ManagementAction ;
  rdfs:range beecore:Swarm .

beecore:rears a owl:ObjectProperty ;
  rdfs:label "rears" ;
  rdfs:domain beecore:QueenRearing ;
  rdfs:range beecore:Queen .

beecore:hasQuantity a owl:DatatypeProperty ;
  rdfs:label "has quantity" ;
  rdfs:domain beecore:ManagementAction ;
  rdfs:range xsd:decimal .

beecore:hasUnit a owl:DatatypeProperty ;
