APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
ADMIN_API_TOKEN=
RUNTIME_SECRET_ENCRYPTION_KEY=
POSTGRES_DSN=postgresql://bee:bee@postgres:5432/bee_ingestion
AUTH_POSTGRES_DB=bee_identity
AUTH_POSTGRES_USER=bee_auth
AUTH_POSTGRES_PASSWORD=bee_auth
AUTH_POSTGRES_DSN=postgresql://bee_auth:bee_auth@auth-postgres:5432/bee_identity
AUTH_POSTGRES_SCHEMA=auth
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=kb_chunks_t3large_v1
EMBEDDING_PROVIDER=dummy
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=120
KG_EXTRACTION_PROVIDER=auto
KG_BASE_URL=https://api.openai.com/v1
KG_API_KEY=
KG_MODEL=gpt-5-mini
KG_REASONING_EFFORT=minimal
KG_TIMEOUT_SECONDS=90
KG_PROMPT_VERSION=v2
KG_ONTOLOGY_PATH=/app/data/beecore.ttl
KG_MIN_CONFIDENCE=0.7
